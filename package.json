{
  "name": "fuelops-rota",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile-friendly rota and reminder app for a UK fuel station",
  "engines": {
    "node": ">=22.5.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "npm --workspace backend start",
    "build": "npm --workspace frontend run build",
    "dev": "npm --workspace frontend run dev",
    "backend": "npm --prefix backend start",
    "frontend": "npm --prefix frontend run dev"
  }
}
